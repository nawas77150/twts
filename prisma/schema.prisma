generator client {
  provider = "prisma-client-js"
}

// ⚠️ PRODUCTION: PostgreSQL — do NOT change to sqlite.
// Raw SQL in posting-lock.ts and circuit-breaker.ts uses PostgreSQL syntax
// (NOW(), ::INTEGER, ::BIGINT, ::TEXT). Changing provider will break them.
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Submitter {
  id                String       @id @default(cuid())
  twitterId         String       @unique  // X user ID from OAuth 2.0
  username          String       @unique
  displayName       String?
  profileImage      String?
  oauth2AccessToken String?      // OAuth 2.0 access token (encrypted at rest)
  oauth2RefreshToken String?     // OAuth 2.0 refresh token (encrypted at rest)
  customLimits      Json?        // Per-user limit overrides, e.g. {"submissionDailyCap": 50}
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  submissions       Submission[]

  @@index([createdAt])            // admin list ordering
}

model Submission {
  id          String    @id @default(cuid())
  message     String
  normalizedMessage String @default("") // Normalized fingerprint for duplicate detection (strips zero-width chars, normalizes Unicode)
  status      String    @default("pending") // pending, censored, posting, post_failed, rejected, posted
  tweetId     String?   // X tweet ID after posting
  postMethod  String?   // "direct" | "retry" | "fallback" — which method posted this tweet
  postError   String?   // Error message from last failed post attempt (cleared on success)
  category      String?   // optional category/tag
  filterReasons String?   // JSON array of filter reasons e.g. ["blocked_word:kontol","contains_mention"]
  submitterId   String
  submitter   Submitter @relation(fields: [submitterId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])                          // filter by status, GROUP BY status (index-only scan)
  @@index([status, postMethod])              // post method stats: WHERE posted GROUP BY postMethod (index-only scan)
  @@index([createdAt])                        // time-window queries
  @@index([submitterId, status])              // "count MY pending submissions"
  @@index([status, updatedAt])                // "last posted submission"
  @@index([submitterId, createdAt])           // per-user cooldown, daily cap, user list
  @@index([submitterId, status, updatedAt])   // per-user post daily cap
  @@index([submitterId, normalizedMessage, createdAt])  // duplicate detection: same user, same fingerprint, within 24h
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique   // "x_cookie_string", "x_query_id", "x_bearer_token"
  value     String             // The actual value
  updatedAt DateTime @updatedAt
}

model LimitHit {
  id          String   @id @default(cuid())
  username    String
  limitType   String   // "cooldown" | "daily_cap" | "pending_cap" | "global_cap" | "post_cap"
  createdAt   DateTime @default(now())

  @@index([limitType, createdAt])
  @@index([username, createdAt])
}

// Server-side OAuth state storage — eliminates dependency on browser cookies
// for PKCE code_verifier and CSRF state. Fixes mobile login where X app's
// WebView has a separate cookie store from Chrome/Safari.
model OAuthFlow {
  id            String   @id @default(cuid())
  codeVerifier  String   // PKCE code_verifier
  state         String   // Full CSRF state string (flowId.randomState)
  createdAt     DateTime @default(now())
  expiresAt     DateTime // 10 min TTL

  @@index([expiresAt])  // for cleanup: deleteMany({ where: { expiresAt: { lt: now } } })
}
