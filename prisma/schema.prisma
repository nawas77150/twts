generator client {
  provider = "prisma-client-js"
}

// ⚠️ PRODUCTION: PostgreSQL — do NOT change to sqlite.
// Raw SQL in posting-lock.ts and circuit-breaker.ts uses PostgreSQL syntax
// (NOW(), ::INTEGER, ::BIGINT, ::TEXT). Changing provider will break them.
datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_DATABASE_URL")
  directUrl = env("POSTGRES_DATABASE_URL_UNPOOLED")
}

model Submitter {
  id                String       @id @default(cuid())
  twitterId         String       @unique  // X user ID from OAuth 2.0
  username          String       @unique
  displayName       String?
  profileImage      String?
  oauth2AccessToken String?      // OAuth 2.0 access token (for user identity)
  oauth2RefreshToken String?     // OAuth 2.0 refresh token
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  submissions       Submission[]

  @@index([createdAt])            // admin list ordering
  @@index([oauth2AccessToken])    // anon OAuth lookup
}

model Submission {
  id          String    @id @default(cuid())
  message     String
  status      String    @default("pending") // pending, post_failed, rejected, posted
  tweetId     String?   // X tweet ID after posting
  postMethod  String?   // "direct" | "retry" | "fallback" — which method posted this tweet
  postError   String?   // Error message from last failed post attempt (cleared on success)
  category      String?   // optional category/tag
  filterReasons String?   // JSON array of filter reasons e.g. ["blocked_word:kontol","contains_mention"]
  submitterId   String
  submitter   Submitter @relation(fields: [submitterId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])                          // filter by status, GROUP BY status (index-only scan)
  @@index([status, postMethod])              // post method stats: WHERE posted GROUP BY postMethod (index-only scan)
  @@index([createdAt])                        // time-window queries
  @@index([submitterId, status])              // "count MY pending submissions"
  @@index([status, updatedAt])                // "last posted submission"
  @@index([submitterId, createdAt])           // per-user cooldown, daily cap, user list
  @@index([submitterId, status, updatedAt])   // per-user post daily cap
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique   // "x_cookie_string", "x_query_id", "x_bearer_token"
  value     String             // The actual value
  updatedAt DateTime @updatedAt
}
